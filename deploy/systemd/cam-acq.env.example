# Copy to /etc/cam-acq/cam-acq.env and edit.
# systemd units load this via EnvironmentFile.

CAM_ACQ_ROOT=/home/besolt/works/cam_acq

# App settings (same keys as project .env; paths should be absolute for systemd)
STORAGE_PATH=/mnt/data_pool/recordings
STORAGE_PATH_SUB=/var/lib/cam-acq/recordings
LOG_PATH=/var/lib/cam-acq/logs
HEALTHCHECK_OUTPUT_DIR=/var/lib/cam-acq/healthcheck
