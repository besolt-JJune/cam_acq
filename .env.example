# cam_acq 환경 설정 예시
# camera_index는 0부터 (CAMERA0_IP의 0은 IP octet이 아님)
# 4-port NIC 직결 예: enp22s0→10.10.1.x, enp26s0→10.10.4.x (docs/09_network_topology.md)

# === Camera ===
# NUM_CAMERAS=N → CAMERA0_IP .. CAMERA{N-1}_IP required (0-based index)
NUM_CAMERAS=2
CAMERA0_IP=10.10.1.101
CAMERA1_IP=10.10.4.101
# CAMERA0_INTERFACE=enp22s0
# CAMERA1_INTERFACE=enp26s0
# --- 3대 예시 ---
# NUM_CAMERAS=3
# CAMERA2_IP=10.10.2.101
# CAMERA2_INTERFACE=enp23s0

PIXEL_FORMAT=BayerRG8
# Demosaic pattern for GStreamer bayer2rgb: RGGB | GRBG | GBRG | BGGR
BAYER_FORMAT=RGGB
# SDK Width/Height 조회 실패 시에만 사용 (0=auto)
CAMERA_WIDTH=0
CAMERA_HEIGHT=0

# === Image / Detection ===
RESIZE_WIDTH=960
RESIZE_HEIGHT=540
# cpu_sdk (default) | gpu_phase3 (Phase 3 path, deferred) | gpu_phase4 (Phase 4)
DEBAYER_MODE=cpu_sdk

# === Recording ===
RECORDING_BUFFER_SEC=10
RECORDING_SPLIT_INTERVAL_SEC=60
# Phase 4 NVENC 프로파일링 후 H264 또는 H265 확정
ENCODING_CODEC=H265
ENCODING_BITRATE_MBPS=12

# === Storage (녹화 + 용량 관리 공통) ===
# STORAGE_PATH: 운영 저장소 (예: SSD mount). 사용 불가 시 STORAGE_PATH_SUB로 fallback.
STORAGE_PATH=/data/recordings
STORAGE_PATH_SUB=./recordings
STORAGE_MANAGEMENT=FIFO_DELETE
STORAGE_FULL_PERCENTAGE=90

# === Detection (YOLOv8m, build 후 engine 경로) ===
# Omit DETECTION_MODEL_PATH to auto-pick models/yolov8m_person_b{NUM_CAMERAS}_gpu{GPU_ID}_fp16.engine
# person-only 배포 (80-class head + runtime filter); coco 전체는 yolov8m.onnx / yolov8m_b{N}_gpu0_fp16.engine
# DETECTION_MODEL_PATH=models/yolov8m_person_b2_gpu0_fp16.engine
DETECTION_ONNX_PATH=models/yolov8m_person.onnx
DETECTION_CONFIDENCE=0.5
DETECTION_INPUT_SIZE=640
# DeepStream-Yolo parser (scripts/setup_deepstream_yolo.sh)
DEEPSTREAM_YOLO_LIB=third_party/DeepStream-Yolo/nvdsinfer_custom_impl_Yolo/libnvdsinfer_custom_impl_Yolo.so

# === Time sync (PTP 미사용 — host clock) ===
TIMESTAMP_RESET_ON_SESSION=true
CROSS_CAMERA_SKEW_TOLERANCE_MS=50

# === Monitoring ===
MONITORING_WEB_PORT=8080
UI_MAX_DISPLAY_FPS=15
SYSTEM_METRICS_POLL_SEC=2
CPU_WARN_PERCENT=85
RAM_WARN_PERCENT=85
GPU_UTIL_WARN_PERCENT=90
GPU_TEMP_WARN_C=80
GPU_TEMP_CRITICAL_C=90

# === System ===
LOG_PATH=/var/log/cam_acq
HEALTHCHECK_OUTPUT_DIR=/var/log/cam_acq/healthcheck
GPU_ID=0

# === GigE tuning / recovery (Phase 2) ===
SOCKET_BUFFER_MIN_BYTES=10485760
GIGE_RECOVERY_RETRY_SEC=2
GIGE_RECOVERY_MAX_ATTEMPTS=5
GIGE_FEATURE_BACKUP_DIR=./healthcheck/feature_backup
