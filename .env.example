# cam_acq нҷҳкІҪ м„Өм • мҳҲмӢң
# camera_indexлҠ” 0л¶Җн„° (CAMERA0_IPмқҳ 0мқҖ IP octetмқҙ м•„лӢҳ)

# === Camera ===
NUM_CAMERAS=3
CAMERA0_IP=192.168.1.101
CAMERA1_IP=192.168.1.102
CAMERA2_IP=192.168.1.103

PIXEL_FORMAT=BayerRG8
# SDK Width/Height мЎ°нҡҢ мӢӨнҢЁ мӢңм—җл§Ң мӮ¬мҡ© (0=auto)
CAMERA_WIDTH=0
CAMERA_HEIGHT=0

# === Image / Detection ===
RESIZE_WIDTH=960
RESIZE_HEIGHT=540

# === Recording ===
RECORDING_BUFFER_SEC=10
RECORDING_SPLIT_INTERVAL_SEC=60
# Phase 4 NVENC н”„лЎңнҢҢмқјл§Ғ нӣ„ H264 лҳҗлҠ” H265 нҷ•м •
ENCODING_CODEC=H265
ENCODING_BITRATE_MBPS=12

# === Storage (л…№нҷ” + мҡ©лҹү кҙҖлҰ¬ кіөнҶө) ===
STORAGE_PATH=/data/recordings
STORAGE_MANAGEMENT=FIFO_DELETE
STORAGE_FULL_PERCENTAGE=90

# === Detection (YOLOv8m, build нӣ„ engine кІҪлЎң) ===
DETECTION_MODEL_PATH=models/yolov8m_person.engine
DETECTION_CONFIDENCE=0.5
DETECTION_INPUT_SIZE=640

# === PTP ===
PTP_ENABLE=true
PTP_SYNC_TOLERANCE_US=10

# === Monitoring ===
MONITORING_WEB_PORT=8080
UI_MAX_DISPLAY_FPS=15

# === System ===
LOG_PATH=/var/log/cam_acq
HEALTHCHECK_OUTPUT_DIR=/var/log/cam_acq/healthcheck
GPU_ID=0
